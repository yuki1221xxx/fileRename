<Window x:Class="FileRename.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ファイル リネーム &amp; 移動"
        Width="1040" Height="780"
        MinWidth="740" MinHeight="540"
        Background="#EEF0F3"
        FontFamily="Meiryo UI"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#EEF0F3">
        <TabControl Background="#EEF0F3"
                    BorderThickness="0"
                    Padding="8,8,8,0"
                    Margin="4">

            <!-- ══ リネームタブ ══════════════════════════ -->
            <TabItem Header="  リネーム  ">
                <DockPanel Background="#EEF0F3">

                    <!-- ヘッダー（行追加ボタン） -->
                    <Border DockPanel.Dock="Top"
                            Background="#EEF0F3"
                            Padding="10,8,10,4">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="AddRowBtn"
                                    Content="＋ 行を追加"
                                    Style="{StaticResource FlatBtn}"
                                    Background="#0D6EFD"
                                    FontWeight="Bold"
                                    Padding="14,7"
                                    Click="AddRowBtn_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- スクロール可能な行エリア -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="#EEF0F3"
                                  Padding="2,0,2,10">
                        <StackPanel x:Name="RowsPanel"/>
                    </ScrollViewer>

                </DockPanel>
            </TabItem>

            <!-- ══ ZIP化タブ ══════════════════════════════ -->
            <TabItem Header="  ZIP化  ">
                <ScrollViewer Background="#EEF0F3" Padding="20">
                    <Border Background="White"
                            CornerRadius="8"
                            MaxWidth="680"
                            HorizontalAlignment="Left">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="3"
                                              Direction="270" Color="#1A000000"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- カードヘッダー -->
                            <Border Grid.Row="0" Background="#495057" CornerRadius="8,8,0,0">
                                <TextBlock Text="  フォルダをZIP化"
                                           Foreground="White" FontWeight="Bold"
                                           FontSize="14" Padding="0,9"/>
                            </Border>

                            <!-- フォーム本体 -->
                            <Grid Grid.Row="1" Margin="18,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 対象フォルダ -->
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="対象フォルダ"
                                           FontSize="13" VerticalAlignment="Center"
                                           Margin="0,0,0,10"/>
                                <TextBox   Grid.Row="0" Grid.Column="1"
                                           x:Name="ZipSrcBox"
                                           Style="{StaticResource FlatEntry}"
                                           Background="#F8F9FA" IsReadOnly="True"
                                           Margin="0,0,8,10"/>
                                <Button    Grid.Row="0" Grid.Column="2"
                                           Content="選択"
                                           Style="{StaticResource FlatBtn}"
                                           Background="#0D6EFD" Padding="12,5"
                                           Margin="0,0,0,10"
                                           Click="ZipSrcBtn_Click"/>

                                <!-- 保存先フォルダ -->
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="保存先フォルダ"
                                           FontSize="13" VerticalAlignment="Center"
                                           Margin="0,0,0,10"/>
                                <TextBox   Grid.Row="1" Grid.Column="1"
                                           x:Name="ZipDestBox"
                                           Style="{StaticResource FlatEntry}"
                                           Background="#F8F9FA" IsReadOnly="True"
                                           Margin="0,0,8,10"/>
                                <Button    Grid.Row="1" Grid.Column="2"
                                           Content="選択"
                                           Style="{StaticResource FlatBtn}"
                                           Background="#6C757D" Padding="12,5"
                                           Margin="0,0,0,10"
                                           Click="ZipDestBtn_Click"/>

                                <!-- ZIPファイル名 -->
                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="ZIPファイル名"
                                           FontSize="13" VerticalAlignment="Center"
                                           Margin="0,0,0,10"/>
                                <TextBox   Grid.Row="2" Grid.Column="1"
                                           x:Name="ZipNameBox"
                                           Style="{StaticResource FlatEntry}"
                                           Margin="0,0,8,10"/>
                                <TextBlock Grid.Row="2" Grid.Column="2"
                                           Text="(.zip 自動)"
                                           FontSize="11" Foreground="#6C757D"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,10"/>

                                <!-- 実行ボタン -->
                                <StackPanel Grid.Row="3" Grid.ColumnSpan="3"
                                            Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="  ZIP化する  "
                                            Style="{StaticResource FlatBtn}"
                                            Background="#198754"
                                            FontWeight="Bold" FontSize="14"
                                            Padding="18,9"
                                            Click="ZipBtn_Click"/>
                                    <TextBlock x:Name="ZipStatusText"
                                               VerticalAlignment="Center"
                                               FontSize="13" Margin="14,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
